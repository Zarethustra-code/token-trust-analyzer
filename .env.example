# ---- AI-generated content detection (Phase 2) ----
# Backend for the AI-text check: local (default; offline two-model SLM pipeline,
# needs `pip install -r requirements-slm.txt`) | anthropic (Claude API) | off.
AI_DETECTOR_BACKEND=local
# Local-backend model overrides (Hugging Face model ids). The classifier decides
# is_ai_generated + confidence; the SLM writes the short reason.
AI_DETECTOR_CLASSIFIER_MODEL=Hello-SimpleAI/chatgpt-detector-roberta
AI_DETECTOR_SLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# Anthropic API key. Only needed when AI_DETECTOR_BACKEND=anthropic. The rest of
# the pipeline runs without it.
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- On-chain data sources (Phase 1) ----
# GoPlus Token Security is the PRIMARY raw-signal source (honeypot, taxes, holder
# distribution, contract privileges, LP lock). The public endpoint needs NO key
# for single-token queries; set a key only to raise rate limits.
GOPLUS_API_KEY=
# Honeypot.is is an independent, simulation-based honeypot cross-check (keyless).
# Optional key raises rate limits (sent as an X-API-KEY header).
HONEYPOT_IS_API_KEY=
# Etherscan V2 (multichain) API key — used for verified-source + contract age.
# https://etherscan.io/apis
ETHERSCAN_API_KEY=
# JSON-RPC endpoint for the target chain (e.g. an Alchemy/Infura/public RPC URL).
# Fallback for direct ERC-20 reads (name/symbol/decimals/supply, owner()).
WEB3_RPC_URL=
# Default chain if a request doesn't specify one. Supported: ethereum | base
CHAIN=ethereum

# ---- CROO Agent Protocol / CAP (Phase 2) ----
# Leave blank to run the CAP wrapper in local simulation mode. To serve real,
# paid orders you need CROO_SDK_KEY + CROO_API_URL + CROO_WS_URL (all required).
# SDK key format: croo_sk_...
CROO_SDK_KEY=
# CROO API base URL.
CROO_API_URL=
# CROO websocket URL — REQUIRED by the SDK Config for the event stream.
CROO_WS_URL=
# Base chain RPC (optional; used for on-chain reads / settlement).
BASE_RPC_URL=
# The priced service id created on the CROO Agent Store dashboard.
CROO_SERVICE_ID=
# Provider wallet address (settlement / logging).
CROO_WALLET_ADDRESS=

# ---- Local server (optional) ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
